[
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"La familia de Marta","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"familia","payload":{"passages":[{"id":"p1","body":"Hola, me llamo Marta. Vivo en una casa con mi madre, mi padre y mi hermano pequeño. Mi hermano se llama Luis y tiene seis años. Tenemos un perro que se llama Toby. Somos una familia feliz."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿Cómo se llama el hermano de Marta?","options":[{"id":"a","text":"Toby"},{"id":"b","text":"Luis"},{"id":"c","text":"Marta"}],"answer":"b"},{"id":"q2","kind":"mcq","stem":"¿Cuántos años tiene el hermano?","options":[{"id":"a","text":"Seis años"},{"id":"b","text":"Diez años"},{"id":"c","text":"Ocho años"}],"answer":"a"},{"id":"q3","kind":"mcq","stem":"¿Qué animal tiene la familia?","options":[{"id":"a","text":"Un gato"},{"id":"b","text":"Un pájaro"},{"id":"c","text":"Un perro"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"Mi desayuno favorito","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"comida","payload":{"passages":[{"id":"p1","body":"Todas las mañanas desayuno en casa. Bebo un vaso de leche con cacao y como una tostada con mantequilla. También como una manzana. No me gusta el café. Mi desayuno favorito es simple y rico."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿Qué bebe la persona por la mañana?","options":[{"id":"a","text":"Café"},{"id":"b","text":"Leche con cacao"},{"id":"c","text":"Agua"}],"answer":"b"},{"id":"q2","kind":"mcq","stem":"¿Qué fruta come?","options":[{"id":"a","text":"Una manzana"},{"id":"b","text":"Una naranja"},{"id":"c","text":"Un plátano"}],"answer":"a"},{"id":"q3","kind":"mcq","stem":"¿Qué no le gusta?","options":[{"id":"a","text":"La tostada"},{"id":"b","text":"El café"},{"id":"c","text":"La leche"}],"answer":"b"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"VERDADERO_FALSO","examFamily":null,"title":"El apartamento nuevo","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"casa","payload":{"passages":[{"id":"p1","body":"Tengo un apartamento nuevo en el centro de la ciudad. Es pequeño pero bonito. Tiene una habitación, una cocina y un baño. La cocina es grande y tiene una ventana. Me gusta mucho mi apartamento."}],"questions":[{"id":"q1","kind":"truefalse","stem":"El apartamento está en el centro de la ciudad.","answer":"true"},{"id":"q2","kind":"truefalse","stem":"El apartamento tiene dos habitaciones.","answer":"false"},{"id":"q3","kind":"truefalse","stem":"La cocina tiene una ventana.","answer":"true"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"En el supermercado","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"compras","payload":{"passages":[{"id":"p1","body":"Ana va al supermercado los sábados. Hoy compra pan, tomates, queso y una botella de agua. Paga doce euros. La cajera es muy amable. Ana vuelve a casa en autobús con sus bolsas."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿Qué día va Ana al supermercado?","options":[{"id":"a","text":"Los lunes"},{"id":"b","text":"Los sábados"},{"id":"c","text":"Los domingos"}],"answer":"b"},{"id":"q2","kind":"mcq","stem":"¿Cuánto paga Ana?","options":[{"id":"a","text":"Doce euros"},{"id":"b","text":"Veinte euros"},{"id":"c","text":"Diez euros"}],"answer":"a"},{"id":"q3","kind":"mcq","stem":"¿Cómo vuelve Ana a casa?","options":[{"id":"a","text":"En coche"},{"id":"b","text":"A pie"},{"id":"c","text":"En autobús"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"Un día en la escuela","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"escuela","payload":{"passages":[{"id":"p1","body":"Pedro es estudiante. Va a la escuela por la mañana. Su clase favorita es matemáticas. Estudia con sus amigos Juan y Sara. A las dos de la tarde come en casa. Después hace los deberes."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿Cuál es la clase favorita de Pedro?","options":[{"id":"a","text":"Matemáticas"},{"id":"b","text":"Historia"},{"id":"c","text":"Música"}],"answer":"a"},{"id":"q2","kind":"mcq","stem":"¿A qué hora come en casa?","options":[{"id":"a","text":"A la una"},{"id":"b","text":"A las dos"},{"id":"c","text":"A las tres"}],"answer":"b"},{"id":"q3","kind":"mcq","stem":"¿Qué hace después de comer?","options":[{"id":"a","text":"Duerme"},{"id":"b","text":"Juega"},{"id":"c","text":"Hace los deberes"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"VERDADERO_FALSO","examFamily":null,"title":"Mi ciudad pequeña","prompt":"Lee el texto y responde.","difficulty":"STRETCH","topicTag":"ciudad","payload":{"passages":[{"id":"p1","body":"Vivo en una ciudad pequeña cerca del mar. Hay una plaza, dos parques y una iglesia vieja. No hay aeropuerto. La gente es simpática. En verano hace mucho calor y voy a la playa con mi familia."}],"questions":[{"id":"q1","kind":"truefalse","stem":"La ciudad está cerca del mar.","answer":"true"},{"id":"q2","kind":"truefalse","stem":"En la ciudad hay un aeropuerto.","answer":"false"},{"id":"q3","kind":"truefalse","stem":"En verano hace mucho calor.","answer":"true"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"El horario de Laura","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"rutina","payload":{"passages":[{"id":"p1","body":"Laura se levanta a las siete de la mañana. Toma una ducha y desayuna. A las ocho va al trabajo en metro. Trabaja en una oficina. Por la tarde va al gimnasio. Se acuesta a las once."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿A qué hora se levanta Laura?","options":[{"id":"a","text":"A las siete"},{"id":"b","text":"A las ocho"},{"id":"c","text":"A las seis"}],"answer":"a"},{"id":"q2","kind":"mcq","stem":"¿Cómo va al trabajo?","options":[{"id":"a","text":"En coche"},{"id":"b","text":"En metro"},{"id":"c","text":"Andando"}],"answer":"b"},{"id":"q3","kind":"mcq","stem":"¿Adónde va por la tarde?","options":[{"id":"a","text":"Al cine"},{"id":"b","text":"Al parque"},{"id":"c","text":"Al gimnasio"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"La ropa de invierno","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"ropa","payload":{"passages":[{"id":"p1","body":"En invierno hace mucho frío. Yo llevo un abrigo negro, una bufanda roja y unos guantes. También uso un gorro. Mi color favorito es el rojo. No me gusta llevar sandalias en invierno."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿De qué color es el abrigo?","options":[{"id":"a","text":"Rojo"},{"id":"b","text":"Negro"},{"id":"c","text":"Azul"}],"answer":"b"},{"id":"q2","kind":"mcq","stem":"¿Cuál es su color favorito?","options":[{"id":"a","text":"El rojo"},{"id":"b","text":"El negro"},{"id":"c","text":"El verde"}],"answer":"a"},{"id":"q3","kind":"mcq","stem":"¿Qué no le gusta llevar en invierno?","options":[{"id":"a","text":"Guantes"},{"id":"b","text":"Bufanda"},{"id":"c","text":"Sandalias"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"VERDADERO_FALSO","examFamily":null,"title":"El restaurante del barrio","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"comida","payload":{"passages":[{"id":"p1","body":"Cerca de mi casa hay un restaurante italiano. La comida es muy buena y no es cara. Mi plato favorito es la pizza. Los camareros son amables. El restaurante abre a las siete de la tarde."}],"questions":[{"id":"q1","kind":"truefalse","stem":"El restaurante es italiano.","answer":"true"},{"id":"q2","kind":"truefalse","stem":"La comida es muy cara.","answer":"false"},{"id":"q3","kind":"truefalse","stem":"El restaurante abre por la tarde.","answer":"true"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"Una carta a un amigo","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"amigos","payload":{"passages":[{"id":"p1","body":"Querido Carlos: Estoy de vacaciones en la playa. El hotel es muy bonito y grande. Cada día nado en el mar y como pescado. Hace sol y mucho calor. Vuelvo a casa el domingo. Un abrazo, Diego."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿Dónde está Diego?","options":[{"id":"a","text":"En la montaña"},{"id":"b","text":"En la playa"},{"id":"c","text":"En la ciudad"}],"answer":"b"},{"id":"q2","kind":"mcq","stem":"¿Qué come cada día?","options":[{"id":"a","text":"Pescado"},{"id":"b","text":"Carne"},{"id":"c","text":"Pasta"}],"answer":"a"},{"id":"q3","kind":"mcq","stem":"¿Cuándo vuelve a casa?","options":[{"id":"a","text":"El sábado"},{"id":"b","text":"El lunes"},{"id":"c","text":"El domingo"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"El trabajo de mi padre","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"trabajo","payload":{"passages":[{"id":"p1","body":"Mi padre es médico. Trabaja en un hospital grande. Ayuda a las personas enfermas. Empieza a trabajar a las nueve de la mañana. Le gusta mucho su trabajo. Los fines de semana descansa en casa."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿Qué es el padre?","options":[{"id":"a","text":"Profesor"},{"id":"b","text":"Médico"},{"id":"c","text":"Cocinero"}],"answer":"b"},{"id":"q2","kind":"mcq","stem":"¿Dónde trabaja?","options":[{"id":"a","text":"En un hospital"},{"id":"b","text":"En una escuela"},{"id":"c","text":"En una tienda"}],"answer":"a"},{"id":"q3","kind":"mcq","stem":"¿Qué hace los fines de semana?","options":[{"id":"a","text":"Trabaja más"},{"id":"b","text":"Viaja"},{"id":"c","text":"Descansa en casa"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"VERDADERO_FALSO","examFamily":null,"title":"Mi mascota Nube","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"animales","payload":{"passages":[{"id":"p1","body":"Tengo una gata blanca. Se llama Nube. Es muy pequeña y juega con una pelota. Come pescado y bebe agua. Duerme en mi cama por la noche. Nube es mi mejor amiga."}],"questions":[{"id":"q1","kind":"truefalse","stem":"La gata se llama Nube.","answer":"true"},{"id":"q2","kind":"truefalse","stem":"La gata es negra.","answer":"false"},{"id":"q3","kind":"truefalse","stem":"La gata duerme en la cama por la noche.","answer":"true"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"El cumpleaños de Sofía","prompt":"Lee el texto y responde.","difficulty":"STRETCH","topicTag":"fiesta","payload":{"passages":[{"id":"p1","body":"Hoy es el cumpleaños de Sofía. Tiene ocho años. Hace una fiesta en casa con sus amigos. Hay una tarta de chocolate y muchos globos. Sus amigos traen regalos. Sofía está muy contenta."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿Cuántos años cumple Sofía?","options":[{"id":"a","text":"Siete"},{"id":"b","text":"Ocho"},{"id":"c","text":"Nueve"}],"answer":"b"},{"id":"q2","kind":"mcq","stem":"¿De qué es la tarta?","options":[{"id":"a","text":"De chocolate"},{"id":"b","text":"De fresa"},{"id":"c","text":"De limón"}],"answer":"a"},{"id":"q3","kind":"mcq","stem":"¿Cómo está Sofía?","options":[{"id":"a","text":"Triste"},{"id":"b","text":"Cansada"},{"id":"c","text":"Contenta"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"Un viaje en tren","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"viajes","payload":{"passages":[{"id":"p1","body":"Mañana viajo a Madrid en tren. El tren sale a las diez de la mañana. El viaje dura tres horas. Llevo una maleta pequeña y un libro. En Madrid visito a mi tía Rosa."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿A qué ciudad viaja?","options":[{"id":"a","text":"Barcelona"},{"id":"b","text":"Madrid"},{"id":"c","text":"Sevilla"}],"answer":"b"},{"id":"q2","kind":"mcq","stem":"¿A qué hora sale el tren?","options":[{"id":"a","text":"A las diez"},{"id":"b","text":"A las nueve"},{"id":"c","text":"A las once"}],"answer":"a"},{"id":"q3","kind":"mcq","stem":"¿A quién visita en Madrid?","options":[{"id":"a","text":"A su madre"},{"id":"b","text":"A un amigo"},{"id":"c","text":"A su tía Rosa"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"VERDADERO_FALSO","examFamily":null,"title":"El fin de semana de Tomás","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"ocio","payload":{"passages":[{"id":"p1","body":"Los sábados Tomás juega al fútbol con sus amigos en el parque. Los domingos va al cine con su novia. Le gustan las películas de aventuras. Después toman un café. Tomás no trabaja el fin de semana."}],"questions":[{"id":"q1","kind":"truefalse","stem":"Tomás juega al fútbol los sábados.","answer":"true"},{"id":"q2","kind":"truefalse","stem":"Los domingos Tomás trabaja.","answer":"false"},{"id":"q3","kind":"truefalse","stem":"A Tomás le gustan las películas de aventuras.","answer":"true"}]}},
  {"level":"A1","skill":"COMPRENSION_LECTORA","taskType":"MCQ","examFamily":null,"title":"La habitación de Elena","prompt":"Lee el texto y responde.","difficulty":"CORE","topicTag":"casa","payload":{"passages":[{"id":"p1","body":"La habitación de Elena es grande y luminosa. Hay una cama azul, una mesa y una silla. Sobre la mesa hay muchos libros. En la pared hay una foto de su familia. A Elena le gusta leer en su habitación."}],"questions":[{"id":"q1","kind":"mcq","stem":"¿De qué color es la cama?","options":[{"id":"a","text":"Verde"},{"id":"b","text":"Azul"},{"id":"c","text":"Roja"}],"answer":"b"},{"id":"q2","kind":"mcq","stem":"¿Qué hay sobre la mesa?","options":[{"id":"a","text":"Muchos libros"},{"id":"b","text":"Un ordenador"},{"id":"c","text":"Una lámpara"}],"answer":"a"},{"id":"q3","kind":"mcq","stem":"¿Qué le gusta hacer a Elena en su habitación?","options":[{"id":"a","text":"Dormir"},{"id":"b","text":"Cantar"},{"id":"c","text":"Leer"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"Un café con leche y un croissant","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"comida","payload":{"audioScript":"—Buenos días. ¿Qué desea? —Hola. Quiero un café con leche y un croissant, por favor. —Muy bien. ¿Algo más? —Sí, también un vaso de agua. —Son cuatro euros. —Aquí tiene. Gracias.","speakers":[{"role":"camarero","voice":"es-ES-male"},{"role":"cliente","voice":"es-MX-female"}],"questions":[{"id":"q1","stem":"¿Qué bebida pide el cliente?","options":[{"id":"a","text":"Un café con leche"},{"id":"b","text":"Un té"},{"id":"c","text":"Un zumo"}],"answer":"a"},{"id":"q2","stem":"¿Qué come el cliente?","options":[{"id":"a","text":"Una tostada"},{"id":"b","text":"Un croissant"},{"id":"c","text":"Un bocadillo"}],"answer":"b"},{"id":"q3","stem":"¿Cuánto paga?","options":[{"id":"a","text":"Tres euros"},{"id":"b","text":"Cinco euros"},{"id":"c","text":"Cuatro euros"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"Presentación de Javier","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"personal","payload":{"audioScript":"Hola, me llamo Javier. Tengo veinticinco años. Soy de Colombia, pero ahora vivo en España. Soy profesor de inglés. Me gusta la música y el deporte. Mi color favorito es el verde.","speakers":[{"role":"narrador","voice":"es-CO-male"}],"questions":[{"id":"q1","stem":"¿De dónde es Javier?","options":[{"id":"a","text":"De España"},{"id":"b","text":"De Colombia"},{"id":"c","text":"De México"}],"answer":"b"},{"id":"q2","stem":"¿Cuál es su profesión?","options":[{"id":"a","text":"Profesor de inglés"},{"id":"b","text":"Médico"},{"id":"c","text":"Músico"}],"answer":"a"},{"id":"q3","stem":"¿Cuál es su color favorito?","options":[{"id":"a","text":"El azul"},{"id":"b","text":"El rojo"},{"id":"c","text":"El verde"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"Anuncio en el aeropuerto","prompt":"Escucha y responde.","difficulty":"STRETCH","topicTag":"viajes","payload":{"audioScript":"Atención, pasajeros. El vuelo número doscientos a Buenos Aires sale a las tres de la tarde por la puerta ocho. Por favor, tengan su pasaporte y su tarjeta de embarque. Gracias por viajar con nosotros.","speakers":[{"role":"megafonía","voice":"es-AR-female"}],"questions":[{"id":"q1","stem":"¿A qué ciudad va el vuelo?","options":[{"id":"a","text":"Buenos Aires"},{"id":"b","text":"Madrid"},{"id":"c","text":"Lima"}],"answer":"a"},{"id":"q2","stem":"¿A qué hora sale el vuelo?","options":[{"id":"a","text":"A las dos"},{"id":"b","text":"A las tres"},{"id":"c","text":"A las ocho"}],"answer":"b"},{"id":"q3","stem":"¿Por qué puerta sale?","options":[{"id":"a","text":"La puerta dos"},{"id":"b","text":"La puerta tres"},{"id":"c","text":"La puerta ocho"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"Planes para el sábado","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"ocio","payload":{"audioScript":"—Hola, Marta. ¿Qué haces el sábado? —Hola, Luis. Voy al cine con mi hermana. —¿Qué película veis? —Una película de aventuras. Empieza a las seis. —¡Qué bien! Yo voy al parque.","speakers":[{"role":"chico","voice":"es-ES-male"},{"role":"chica","voice":"es-CL-female"}],"questions":[{"id":"q1","stem":"¿Adónde va Marta el sábado?","options":[{"id":"a","text":"Al cine"},{"id":"b","text":"Al parque"},{"id":"c","text":"Al restaurante"}],"answer":"a"},{"id":"q2","stem":"¿Con quién va Marta?","options":[{"id":"a","text":"Con Luis"},{"id":"b","text":"Con su hermana"},{"id":"c","text":"Con su madre"}],"answer":"b"},{"id":"q3","stem":"¿A qué hora empieza la película?","options":[{"id":"a","text":"A las cinco"},{"id":"b","text":"A las siete"},{"id":"c","text":"A las seis"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"En la tienda de ropa","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"compras","payload":{"audioScript":"—Buenas tardes. ¿Puedo ayudarle? —Sí, busco una camisa azul. —¿Qué talla usa? —La talla mediana. —Aquí tiene. Cuesta veinte euros. —Perfecto, la compro. Gracias.","speakers":[{"role":"dependienta","voice":"es-PE-male"},{"role":"cliente","voice":"es-ES-female"}],"questions":[{"id":"q1","stem":"¿Qué busca el cliente?","options":[{"id":"a","text":"Una camisa azul"},{"id":"b","text":"Unos zapatos"},{"id":"c","text":"Un pantalón"}],"answer":"a"},{"id":"q2","stem":"¿Qué talla usa?","options":[{"id":"a","text":"Pequeña"},{"id":"b","text":"Mediana"},{"id":"c","text":"Grande"}],"answer":"b"},{"id":"q3","stem":"¿Cuánto cuesta la camisa?","options":[{"id":"a","text":"Diez euros"},{"id":"b","text":"Treinta euros"},{"id":"c","text":"Veinte euros"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"La familia de Rosa","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"familia","payload":{"audioScript":"Me llamo Rosa. Vivo con mis padres y mis dos hermanos. Mi hermano mayor tiene veinte años y estudia en la universidad. Mi hermana pequeña tiene diez años. Tenemos un perro grande.","speakers":[{"role":"narradora","voice":"es-MX-female"}],"questions":[{"id":"q1","stem":"¿Cuántos hermanos tiene Rosa?","options":[{"id":"a","text":"Uno"},{"id":"b","text":"Dos"},{"id":"c","text":"Tres"}],"answer":"b"},{"id":"q2","stem":"¿Qué hace el hermano mayor?","options":[{"id":"a","text":"Trabaja"},{"id":"b","text":"Estudia en la universidad"},{"id":"c","text":"Viaja"}],"answer":"b"},{"id":"q3","stem":"¿Qué animal tiene la familia?","options":[{"id":"a","text":"Un gato"},{"id":"b","text":"Un pájaro"},{"id":"c","text":"Un perro grande"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"Reservar una mesa","prompt":"Escucha y responde.","difficulty":"STRETCH","topicTag":"comida","payload":{"audioScript":"—Restaurante El Sol, buenas noches. —Hola, quiero reservar una mesa para el viernes. —¿Para cuántas personas? —Para cuatro personas, a las nueve. —Muy bien. ¿A nombre de quién? —A nombre de Pablo.","speakers":[{"role":"recepcionista","voice":"es-ES-female"},{"role":"cliente","voice":"es-AR-male"}],"questions":[{"id":"q1","stem":"¿Para qué día es la reserva?","options":[{"id":"a","text":"El viernes"},{"id":"b","text":"El sábado"},{"id":"c","text":"El jueves"}],"answer":"a"},{"id":"q2","stem":"¿Para cuántas personas?","options":[{"id":"a","text":"Dos"},{"id":"b","text":"Cuatro"},{"id":"c","text":"Seis"}],"answer":"b"},{"id":"q3","stem":"¿A nombre de quién es la reserva?","options":[{"id":"a","text":"De Pedro"},{"id":"b","text":"De Pablo"},{"id":"c","text":"De Pilar"}],"answer":"b"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"El tiempo de hoy","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"tiempo","payload":{"audioScript":"Buenos días. Hoy en Madrid hace sol y calor. La temperatura es de treinta grados. Por la tarde hay un poco de viento. No llueve. Es un buen día para ir a la piscina.","speakers":[{"role":"presentador","voice":"es-ES-male"}],"questions":[{"id":"q1","stem":"¿Qué tiempo hace hoy en Madrid?","options":[{"id":"a","text":"Hace sol y calor"},{"id":"b","text":"Llueve"},{"id":"c","text":"Nieva"}],"answer":"a"},{"id":"q2","stem":"¿Cuál es la temperatura?","options":[{"id":"a","text":"Veinte grados"},{"id":"b","text":"Treinta grados"},{"id":"c","text":"Diez grados"}],"answer":"b"},{"id":"q3","stem":"¿Qué es un buen día para hacer?","options":[{"id":"a","text":"Ver la tele"},{"id":"b","text":"Dormir"},{"id":"c","text":"Ir a la piscina"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"Direcciones a la farmacia","prompt":"Escucha y responde.","difficulty":"STRETCH","topicTag":"ciudad","payload":{"audioScript":"—Perdone, ¿dónde está la farmacia? —Está muy cerca. Sigue todo recto y gira a la derecha. La farmacia está al lado del banco. —¿Está lejos? —No, a cinco minutos. —Muchas gracias.","speakers":[{"role":"turista","voice":"es-CO-female"},{"role":"vecino","voice":"es-ES-male"}],"questions":[{"id":"q1","stem":"¿Qué busca el turista?","options":[{"id":"a","text":"La farmacia"},{"id":"b","text":"El banco"},{"id":"c","text":"El hospital"}],"answer":"a"},{"id":"q2","stem":"¿Al lado de qué está la farmacia?","options":[{"id":"a","text":"Del supermercado"},{"id":"b","text":"Del banco"},{"id":"c","text":"Del parque"}],"answer":"b"},{"id":"q3","stem":"¿A cuántos minutos está?","options":[{"id":"a","text":"A diez minutos"},{"id":"b","text":"A dos minutos"},{"id":"c","text":"A cinco minutos"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"La rutina de Miguel","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"rutina","payload":{"audioScript":"Me llamo Miguel. Cada día me levanto a las seis y media. Desayuno leche y galletas. Voy a la oficina en bicicleta. Trabajo hasta las tres. Por la tarde, estudio español en casa.","speakers":[{"role":"narrador","voice":"es-CL-male"}],"questions":[{"id":"q1","stem":"¿A qué hora se levanta Miguel?","options":[{"id":"a","text":"A las seis y media"},{"id":"b","text":"A las siete"},{"id":"c","text":"A las ocho"}],"answer":"a"},{"id":"q2","stem":"¿Cómo va a la oficina?","options":[{"id":"a","text":"En coche"},{"id":"b","text":"En bicicleta"},{"id":"c","text":"En autobús"}],"answer":"b"},{"id":"q3","stem":"¿Qué hace por la tarde?","options":[{"id":"a","text":"Duerme"},{"id":"b","text":"Ve la tele"},{"id":"c","text":"Estudia español"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"En la estación de tren","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"viajes","payload":{"audioScript":"—Hola, quiero un billete para Valencia. —¿De ida y vuelta? —Solo de ida, por favor. —Son quince euros. El tren sale a las once del andén dos. —Gracias. ¿Llega pronto? —Sí, a la una.","speakers":[{"role":"taquillero","voice":"es-ES-male"},{"role":"viajera","voice":"es-MX-female"}],"questions":[{"id":"q1","stem":"¿Adónde quiere viajar la mujer?","options":[{"id":"a","text":"A Valencia"},{"id":"b","text":"A Sevilla"},{"id":"c","text":"A Bilbao"}],"answer":"a"},{"id":"q2","stem":"¿Cuánto cuesta el billete?","options":[{"id":"a","text":"Diez euros"},{"id":"b","text":"Quince euros"},{"id":"c","text":"Veinte euros"}],"answer":"b"},{"id":"q3","stem":"¿De qué andén sale el tren?","options":[{"id":"a","text":"Del andén uno"},{"id":"b","text":"Del andén tres"},{"id":"c","text":"Del andén dos"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"Invitación a cenar","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"amigos","payload":{"audioScript":"—Hola, Ana. ¿Quieres cenar en mi casa esta noche? —¡Sí, gracias! ¿A qué hora? —A las ocho. Hago paella. —¡Me encanta la paella! ¿Llevo algo? —Un postre, por favor. —Perfecto, llevo una tarta.","speakers":[{"role":"anfitrión","voice":"es-PE-male"},{"role":"invitada","voice":"es-ES-female"}],"questions":[{"id":"q1","stem":"¿A qué hora es la cena?","options":[{"id":"a","text":"A las ocho"},{"id":"b","text":"A las siete"},{"id":"c","text":"A las nueve"}],"answer":"a"},{"id":"q2","stem":"¿Qué comida prepara el anfitrión?","options":[{"id":"a","text":"Pizza"},{"id":"b","text":"Paella"},{"id":"c","text":"Sopa"}],"answer":"b"},{"id":"q3","stem":"¿Qué lleva Ana?","options":[{"id":"a","text":"Pan"},{"id":"b","text":"Vino"},{"id":"c","text":"Una tarta"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"En el médico","prompt":"Escucha y responde.","difficulty":"STRETCH","topicTag":"salud","payload":{"audioScript":"—Buenos días, doctora. No me siento bien. —¿Qué le pasa? —Me duele la cabeza y tengo fiebre. —¿Desde cuándo? —Desde ayer. —Tiene que descansar y beber mucha agua. Tome esta medicina.","speakers":[{"role":"paciente","voice":"es-AR-male"},{"role":"doctora","voice":"es-ES-female"}],"questions":[{"id":"q1","stem":"¿Qué le duele al paciente?","options":[{"id":"a","text":"La cabeza"},{"id":"b","text":"El estómago"},{"id":"c","text":"La pierna"}],"answer":"a"},{"id":"q2","stem":"¿Desde cuándo está enfermo?","options":[{"id":"a","text":"Desde hoy"},{"id":"b","text":"Desde ayer"},{"id":"c","text":"Desde el lunes"}],"answer":"b"},{"id":"q3","stem":"¿Qué tiene que hacer el paciente?","options":[{"id":"a","text":"Correr"},{"id":"b","text":"Trabajar"},{"id":"c","text":"Descansar y beber agua"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"El nuevo compañero","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"personal","payload":{"audioScript":"—Hola, soy Carlos. Soy nuevo en la clase. —Encantada, Carlos. Soy Lucía. ¿De dónde eres? —Soy de Chile. ¿Y tú? —Yo soy de México. ¿Dónde vives ahora? —Vivo cerca de la escuela.","speakers":[{"role":"chico","voice":"es-CL-male"},{"role":"chica","voice":"es-MX-female"}],"questions":[{"id":"q1","stem":"¿De dónde es Carlos?","options":[{"id":"a","text":"De Chile"},{"id":"b","text":"De México"},{"id":"c","text":"De España"}],"answer":"a"},{"id":"q2","stem":"¿De dónde es Lucía?","options":[{"id":"a","text":"De Chile"},{"id":"b","text":"De México"},{"id":"c","text":"De Perú"}],"answer":"b"},{"id":"q3","stem":"¿Dónde vive Carlos ahora?","options":[{"id":"a","text":"Lejos de la ciudad"},{"id":"b","text":"En el centro"},{"id":"c","text":"Cerca de la escuela"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"Compras en el mercado","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"compras","payload":{"audioScript":"—Buenos días. ¿Qué le pongo? —Quiero un kilo de manzanas y medio kilo de fresas. —¿Algo más? —Sí, tres naranjas. —Son seis euros. —Aquí tiene. Muchas gracias.","speakers":[{"role":"vendedor","voice":"es-ES-male"},{"role":"clienta","voice":"es-CO-female"}],"questions":[{"id":"q1","stem":"¿Cuántas manzanas compra?","options":[{"id":"a","text":"Un kilo"},{"id":"b","text":"Medio kilo"},{"id":"c","text":"Dos kilos"}],"answer":"a"},{"id":"q2","stem":"¿Qué otra fruta compra?","options":[{"id":"a","text":"Plátanos"},{"id":"b","text":"Fresas y naranjas"},{"id":"c","text":"Uvas"}],"answer":"b"},{"id":"q3","stem":"¿Cuánto paga en total?","options":[{"id":"a","text":"Cuatro euros"},{"id":"b","text":"Ocho euros"},{"id":"c","text":"Seis euros"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"El cumpleaños de mamá","prompt":"Escucha y responde.","difficulty":"CORE","topicTag":"familia","payload":{"audioScript":"—Papá, ¿qué regalamos a mamá? —Su cumpleaños es el domingo. Podemos comprar flores. —¡Buena idea! A mamá le gustan las rosas. —Sí, y también hacemos una tarta de fresa. —¡Perfecto!","speakers":[{"role":"hija","voice":"es-MX-female"},{"role":"padre","voice":"es-ES-male"}],"questions":[{"id":"q1","stem":"¿Cuándo es el cumpleaños de mamá?","options":[{"id":"a","text":"El domingo"},{"id":"b","text":"El sábado"},{"id":"c","text":"El lunes"}],"answer":"a"},{"id":"q2","stem":"¿Qué flores le gustan a mamá?","options":[{"id":"a","text":"Los tulipanes"},{"id":"b","text":"Las rosas"},{"id":"c","text":"Las margaritas"}],"answer":"b"},{"id":"q3","stem":"¿De qué hacen la tarta?","options":[{"id":"a","text":"De chocolate"},{"id":"b","text":"De limón"},{"id":"c","text":"De fresa"}],"answer":"c"}]}},
  {"level":"A1","skill":"COMPRENSION_AUDITIVA","taskType":"MCQ","examFamily":null,"title":"En el hotel","prompt":"Escucha y responde.","difficulty":"STRETCH","topicTag":"viajes","payload":{"audioScript":"—Buenas tardes. Tengo una reserva a nombre de García. —Sí, una habitación doble para dos noches. —Exacto. ¿Hay wifi? —Sí, es gratis. Su habitación es la número doce, en el segundo piso. —Gracias.","speakers":[{"role":"recepcionista","voice":"es-ES-female"},{"role":"huésped","voice":"es-PE-male"}],"questions":[{"id":"q1","stem":"¿Para cuántas noches es la reserva?","options":[{"id":"a","text":"Dos noches"},{"id":"b","text":"Tres noches"},{"id":"c","text":"Una noche"}],"answer":"a"},{"id":"q2","stem":"¿El wifi es gratis?","options":[{"id":"a","text":"No, cuesta dinero"},{"id":"b","text":"Sí, es gratis"},{"id":"c","text":"No hay wifi"}],"answer":"b"},{"id":"q3","stem":"¿En qué piso está la habitación?","options":[{"id":"a","text":"En el primer piso"},{"id":"b","text":"En el tercer piso"},{"id":"c","text":"En el segundo piso"}],"answer":"c"}]}}
]
