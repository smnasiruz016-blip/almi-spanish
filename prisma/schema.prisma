// AlmiSpanish data model. The shared engine foundation (auth, billing, AI cost
// ledger) is forked from the AlmiWorld family. The practice layer is an
// ITEM-BANK: a single SpanishItem ↔ SpanishAttempt pair carries every task type via
// a typed `payload` Json, instead of one model per skill.
//
// Spanish is NOT one exam with one pass mark. Content is SHARED BY CEFR LEVEL and
// WRAPPED PER EXAM: a SpanishItem is keyed by (skill, level); Reading/Listening
// items are reused across DELE/SIELE (examFamily = null), while Writing/Speaking
// prompts can be exam-specific (examFamily set). Scoring routes to the right
// engine (src/lib/spanish/engines): DELE (each skill /25 → /100 in two
// level-dependent groups; APTO needs ≥60% total, ≥60% per group AND ≥25% per
// skill), SIELE (each skill 0–250 → 0–1000,
// NO pass/fail, maps to CEFR A1–C1), CCSE (civic 25-MCQ, pass 15/25). All content
// is original Spanish (pan-Hispanic), never copied from Instituto Cervantes /
// Universidad de Salamanca / the Ministry of Interior; results are practice
// estimates — candidates confirm the real requirement with the Spanish consulate,
// registro civil, or their university.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Locale {
  EN
  UR
  AR
  HI
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  passwordHash String
  locale       Locale  @default(EN)
  countryCode  String?
  referralCode String  @unique @default(cuid())

  // Email verification — required before paid feature access.
  emailVerified               DateTime?
  emailVerificationTokenHash  String?   @unique
  emailVerificationExpiresAt  DateTime?
  emailVerificationLastSentAt DateTime?

  // Stripe subscription state — webhook keeps this in lockstep with Stripe.
  stripeCustomerId              String?          @unique
  stripeSubscriptionId          String?          @unique
  subscriptionStatus            String?
  subscriptionPlan              String?
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionCancelAtPeriodEnd Boolean          @default(false)
  trialEndsAt                   DateTime?
  subscriptionTier              SubscriptionTier @default(FREE)

  // Comp Pro access — admin-granted, no Stripe. isProActive()/hasPaidAccess()
  // short-circuit true while compProUntil is in the future, bypassing BOTH the
  // subscription check AND email verification. AlmiSpanish full Pro = AI feedback
  // on Expresión escrita + Expresión oral + the full per-exam mock.
  compProUntil  DateTime?
  compGrantedAt DateTime?
  compGrantedBy String?
  compReason    String?

  // Which CEFR level the user is preparing for (A1–C2). Drives the default mock
  // and which practice content is surfaced. Null = not chosen yet.
  targetLevel CefrLevel?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  spanishAttempts     SpanishAttempt[]
  spanishSessions     SpanishSession[]
  reviews             Review[]

  @@index([email])
  @@index([referralCode])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([compProUntil])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ProcessedWebhook {
  id          String   @id
  eventType   String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model EarlyAccess {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())

  @@index([email])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  text      String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([approved, createdAt])
}

model AICostLedger {
  id               String   @id @default(cuid())
  timestamp        DateTime @default(now())
  userId           String?
  feature          String
  model            String
  inputTokens      Int
  outputTokens     Int
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costCents        Int
  success          Boolean  @default(true)
  errorMessage     String?

  @@index([timestamp(sort: Desc)])
  @@index([userId, timestamp])
  @@index([feature, timestamp])
}

// ===================== AlmiSpanish practice item-bank =====================
// Four skills at six CEFR levels. Content is keyed by (skill, level) and SHARED
// across exams where the skill is the same (Reading/Listening), or made
// exam-specific where the task genuinely differs (Writing/Speaking). The chosen
// EXAM (src/lib/spanish/exams.ts) determines the scale + engine at scoring time.
// DELE = APTO/NO APTO per-group floor; SIELE = 0–1000 placement, no pass/fail;
// CCSE = civic 25-MCQ, 15/25 pass (knowledge test, not CEFR).

// CEFR level — the primary content axis.
enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

// The four Spanish exam skills.
enum SpanishSkill {
  COMPRENSION_AUDITIVA // Listening — objective (pan-Hispanic TTS audio)
  COMPRENSION_LECTORA // Reading — objective
  EXPRESION_ESCRITA // Writing — AI
  EXPRESION_ORAL // Speaking — AI (audio -> Whisper -> grade transcript)
}

// Which exam a Writing/Speaking item targets. NULL = shared item
// (Reading/Listening), reusable across all exams at its level. CCSE = civic
// knowledge MCQ pool (Ministry of Interior 300-question pool), not a CEFR skill.
enum ExamFamily {
  DELE
  SIELE
  CCSE
}

// Task format. Reading/Listening (and CCSE civics) are objective; Writing/Speaking
// are productive.
enum SpanishTaskType {
  // Comprensión (objective)
  MCQ // multiple choice (also CCSE civic questions)
  MATCHING // match items
  VERDADERO_FALSO // true/false (with justification on harder levels)
  SHORT_ANSWER // open short answer
  // Expresión escrita (productive, AI)
  WRITING_TASK // carta / correo / redacción (level + exam aware)
  // Expresión oral (productive, AI)
  SPEAKING_TASK // monólogo / conversación / tareas (level + exam aware)
}

enum SpanishAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  SCORED
}

// Intra-level variety pool — the LEVEL is the main difficulty axis.
enum SpanishDifficulty {
  FOUNDATION
  CORE
  STRETCH
}

model SpanishItem {
  id               String           @id @default(cuid())
  level            CefrLevel
  skill            SpanishSkill
  taskType         SpanishTaskType
  // NULL for shared Reading/Listening items; set for exam-specific Writing/Speaking
  // or for CCSE civic items (examFamily = CCSE).
  examFamily       ExamFamily?
  title            String
  prompt           String           @db.Text
  // Task-specific stimulus + (for objective tasks) the server-side answer key,
  // never sent raw to the client. Shapes by taskType (validated in app code):
  //   reading       { passages:[{id,heading,body}], questions:[{id,kind,stem,options,answer}] }
  //   listening     { audioScript, speakers:[{role,voice}], questions:[{id,stem,options,answer}] }
  //   writing       { situation, instruction, wordMin, wordMax }
  //   speaking      { taskPrompt, prepSeconds, speakSeconds, imageUrl?, imageAlt? }
  payload          Json
  difficulty       SpanishDifficulty @default(CORE)
  guidanceNote     String?           @db.Text
  timeLimitSeconds Int               @default(0)
  topicTag         String            @default("general")
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())

  attempts SpanishAttempt[]

  @@index([level, skill, active, difficulty])
  @@index([level, skill, examFamily, active])
  @@index([level, taskType, active])
}

model SpanishAttempt {
  id       String               @id @default(cuid())
  userId   String
  itemId   String
  level    CefrLevel
  skill    SpanishSkill
  taskType SpanishTaskType
  // The exam the user is practising for — drives the scale + engine (src/lib/spanish/exams.ts id).
  examId   String
  status   SpanishAttemptStatus @default(IN_PROGRESS)

  // The user's raw response; shape depends on skill:
  //   reading / listening   { answers: { [questionId]: string | string[] } }
  //   writing               { text: string }
  //   speaking              { transcript: string }
  response Json @default("{}")

  pointsEarned Int @default(0)
  pointsMax    Int @default(0)

  // Per-skill engine estimate (shape depends on the exam):
  //   DELE   { outOf25, group: "I"|"II", belowGroupFloor }
  //   SIELE  { score (/250), cefr }
  //   CCSE   { correct, total: 25, passed }
  // Honest estimate — never a fabricated official result.
  scoreEstimate Json?

  // AI trait feedback payload for Writing/Speaking (qualitative; no fake score).
  feedback Json?

  aiModel   String?
  costCents Int?
  latencyMs Int?

  sessionId   String?
  sessionStep Int?

  timeSpentSeconds Int       @default(0)
  startedAt        DateTime  @default(now())
  submittedAt      DateTime?
  updatedAt        DateTime  @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  item    SpanishItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  session SpanishSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, status, submittedAt])
  @@index([userId, startedAt])
  @@index([itemId])
  @@index([sessionId, sessionStep])
}

// ===================== Practice sets + full mock =====================
// PRACTICE_SET = several items of one SKILL at one LEVEL for one EXAM. MOCK = the
// full exam for one LEVEL, all four skills in order. Each skill scored on the
// exam's own scale via its engine — no fabricated composite.

enum SpanishSessionMode {
  PRACTICE_SET
  MOCK
}

enum SpanishSessionStatus {
  IN_PROGRESS
  COMPLETED
}

model SpanishSession {
  id     String @id @default(cuid())
  userId String

  mode              SpanishSessionMode
  examId            String
  level             CefrLevel
  // The single skill for a PRACTICE_SET; null for a MOCK (all four skills).
  skill             SpanishSkill?
  targetCount       Int
  currentStep       Int                  @default(0)
  currentDifficulty SpanishDifficulty    @default(CORE)
  plan              Json?
  status            SpanishSessionStatus  @default(IN_PROGRESS)

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts SpanishAttempt[]

  @@index([userId, status, startedAt])
}
